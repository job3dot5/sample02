# -----------------------------------------------------------------------------
# Docker Compose variables for backend/frontend example stack (dev)
# Copy to .env and adjust values as needed.
# -----------------------------------------------------------------------------

# Backend (Express BFF)
BACKEND_API_BASE_URL=https://nginx
BACKEND_API_USERNAME=change_me
BACKEND_API_PASSWORD=change_me
BACKEND_FRONTEND_ORIGIN=http://localhost:5173
BACKEND_JWT_ISSUER=urn:sample02:api
BACKEND_JWT_AUDIENCE=urn:sample02:client

# Dev only: allow self-signed TLS cert between backend container and nginx.
BACKEND_NODE_TLS_REJECT_UNAUTHORIZED=0

# Frontend (Vue/Vite)
FRONTEND_BACKEND_URL=http://localhost:3000
